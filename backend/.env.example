# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce"

# JWT (MUST be 64+ characters — app will fail to boot otherwise)
JWT_SECRET="your-super-secret-jwt-key-must-be-at-least-64-characters-long-change-in-production"
JWT_EXPIRES_IN="15m"

REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key-must-be-at-least-64-characters-long-change-in-production"
REFRESH_TOKEN_EXPIRES_IN="7d"

# App
PORT=4000
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000"

# Payment Settings
PAYMENT_GATEWAY="mock"
COD_MAX_AMOUNT=5000

# Future: Payment Gateway
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Cloudinary (Phase 6: File Upload)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Future: S3 (if switching from Cloudinary)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
AWS_REGION=""

# Future: Email
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@yourstore.com"

# Redis Cache (Phase 9A)
REDIS_HOST=
REDIS_PORT=
